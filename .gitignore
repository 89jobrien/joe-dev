# Atelier gitignore
.ctx/*
!.ctx/HANDOFF.*.yaml
!.ctx/HANDOFF.*.*.yaml
!.ctx/handoff.*.config.toml.example
# explicitly keep state/rendered files ignored (redundant with global, but clear intent)
.ctx/HANDOFF.state.yaml
.ctx/HANDOFF.md
.ctx/HANDOVER.md
.ctx/HANDUP.json
.claude/*.local.md
.claude/settings.local.json
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
skills/*/scripts/test_*.py
.DS_Store
**/.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
*.log
*.tmp

# handoff-begin
.ctx/*
!.ctx/HANDOFF.*.yaml
.ctx/HANDOFF.*.state.yaml
!.ctx/handoff.*.config.toml.example
.ctx/.initialized
# handoff-end
