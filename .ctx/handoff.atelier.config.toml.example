# handoff.<repo>.config.toml — machine-local runtime vars
#
# Copy this file to handoff.atelier.config.toml and fill in your values.
# This file is gitignored. The .example is committed as the reference.
#
# Variables defined here are loaded by handon at session start and injected
# into session context. Reference them in skills and agents as {{ var }}.

[vars]
# Root directory where all projects live
dev_dir = "~/dev"

# Claude config and dotfiles root
dotfiles = "~/.claude"

# Primary projects this repo serves (used by forge, sentinel, herald)
projects = ["minibox", "doob", "devkit", "maestro"]
